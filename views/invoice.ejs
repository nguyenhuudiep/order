<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hóa Đơn #<%= orderId %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body data-order-id="<%= orderId %>">
  <main class="page invoice-page">
    <section class="panel invoice-panel">
      <header class="invoice-head">
        <div>
          <h1>Hóa Đơn Bán Hàng</h1>
          <p>Mã đơn: #<%= orderId %></p>
        </div>
        <div class="row-actions">
          <a id="pdf-btn" class="admin-link" target="_blank" href="/api/admin/orders/<%= orderId %>/pdf">Tải PDF</a>
          <button id="print-btn">In hóa đơn</button>
          <a href="/admin" class="admin-link">Về dashboard</a>
        </div>
      </header>

      <div id="invoice-content">
        <p>Đang tải dữ liệu đơn hàng...</p>
      </div>
    </section>
  </main>

  <script>
    const orderId = Number(document.body.dataset.orderId);
    const invoiceContent = document.getElementById('invoice-content');
    const printBtn = document.getElementById('print-btn');
    const statusMap = {
      pending: 'Chờ xác nhận',
      confirmed: 'Đã xác nhận',
      preparing: 'Đang chuẩn bị',
      delivering: 'Đang giao',
      completed: 'Hoàn thành',
      cancelled: 'Đã hủy'
    };

    function formatMoney(value) {
      return Number(value).toLocaleString('vi-VN');
    }

    async function loadInvoice() {
      const response = await fetch(`/api/admin/orders/${orderId}`);
      const order = await response.json();

      if (!response.ok) {
        invoiceContent.innerHTML = `<p>${order.message || 'Không tải được hóa đơn.'}</p>`;
        return;
      }

      const rows = order.items.map((item, index) => `
        <tr>
          <td>${index + 1}</td>
          <td>${item.ItemName}</td>
          <td>${item.Quantity}</td>
          <td>${formatMoney(item.UnitPrice)} VND</td>
          <td>${formatMoney(item.Quantity * item.UnitPrice)} VND</td>
        </tr>
      `).join('');

      invoiceContent.innerHTML = `
        <div class="invoice-meta">
          <p><strong>Cửa hàng:</strong> ${order.StoreName || '-'}</p>
          <p><strong>Bàn:</strong> ${order.TableNumber || '-'}</p>
          <p><strong>Khách hàng:</strong> ${order.CustomerName}</p>
          <p><strong>Trạng thái:</strong> ${statusMap[order.Status] || order.Status}</p>
          <p><strong>Thời gian:</strong> ${new Date(order.CreatedAt).toLocaleString('vi-VN')}</p>
          <p><strong>Ghi chú:</strong> ${order.Note || '-'}</p>
        </div>
        <table class="invoice-table">
          <thead>
            <tr>
              <th>STT</th>
              <th>Món</th>
              <th>SL</th>
              <th>Đơn giá</th>
              <th>Thành tiền</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
        <h2 class="invoice-total">Tổng thanh toán: ${formatMoney(order.TotalAmount)} VND</h2>
      `;
    }

    printBtn.addEventListener('click', () => window.print());
    loadInvoice();
  </script>
</body>
</html>
